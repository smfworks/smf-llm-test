# API Keys (set one or more depending on which providers you use)
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local - no API key needed if running on localhost)
# OLLAMA_HOST=http://localhost:11434

# Optional: Set to skip specific provider tests
# SKIP_OLLAMA=false
# SKIP_OPENAI=false
# SKIP_ANTHROPIC=false
# SKIP_OPENROUTER=false
